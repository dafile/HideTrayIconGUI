<Window x:Class="HideTrayIconGUI.HiddenListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="隐藏列表管理" Width="700" Height="450"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" Background="#F5F5F5"
        Loaded="OnLoaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Click="Refresh_Click" Margin="0,0,8,0"/>
            <Button Content="移除选中" Click="RemoveSelected_Click" Margin="0,0,8,0"
                    Background="#D32F2F" Foreground="White"/>
            <Button Content="全选" Click="SelectAll_Click" Margin="0,0,8,0"/>
            <Button Content="取消" Click="DeselectAll_Click" Margin="0,0,8,0"/>
            <TextBlock x:Name="CountText" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#666"/>
        </StackPanel>

        <!-- Hidden items list -->
        <DataGrid Grid.Row="1" x:Name="HiddenGrid" IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="选" Width="35"
                                        Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="进程名" Binding="{Binding ProcessName}" Width="*" MinWidth="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="提示文本" Binding="{Binding Tooltip}" Width="1.5*" MinWidth="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="区域" Binding="{Binding Area}" Width="65" IsReadOnly="True"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom -->
        <TextBlock Grid.Row="2" Text="提示: 移除选中会从规则列表删除并尝试恢复显示" Foreground="#999"
                   Margin="0,6,0,0" FontSize="12"/>
    </Grid>
</Window>
