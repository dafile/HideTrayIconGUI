<Window x:Class="HideTrayIconGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HideTrayIcon GUI" Width="860" Height="620"
        MinWidth="680" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Loaded="OnLoaded"
        Closing="OnClosing"
        StateChanged="OnStateChanged">
    <Window.Resources>
        <!-- Right-click context menu for icon list -->
        <ContextMenu x:Key="IconContextMenu">
            <MenuItem Header="隐藏此项" Click="CtxHide_Click"/>
            <MenuItem Header="显示此项" Click="CtxShow_Click"/>
            <Separator/>
            <MenuItem Header="复制进程名" Click="CtxCopyName_Click"/>
            <MenuItem Header="复制提示文本" Click="CtxCopyTooltip_Click"/>
        </ContextMenu>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="8,6"
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="刷新" Click="Refresh_Click" Margin="0,0,6,0"/>
                    <Button Content="隐藏选中" Click="HideSelected_Click" Margin="0,0,6,0"
                            Background="#D32F2F" Foreground="White"/>
                    <Button Content="显示选中" Click="ShowSelected_Click" Margin="0,0,6,0"/>
                    <Button Content="全选" Click="SelectAll_Click" Margin="0,0,6,0"/>
                    <Button Content="取消" Click="DeselectAll_Click" Margin="0,0,6,0"/>
                    <Button Content="隐藏列表" Click="HiddenList_Click" Margin="0,0,6,0"
                            Background="#1976D2" Foreground="White"/>
                    <Button Content="日志" Click="ViewLog_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="筛选:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="FilterCombo" Width="80" VerticalAlignment="Center"
                              SelectionChanged="Filter_Changed" Margin="0,0,12,0">
                        <ComboBoxItem Content="全部" IsSelected="True"/>
                        <ComboBoxItem Content="可见"/>
                        <ComboBoxItem Content="已隐藏"/>
                    </ComboBox>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#666"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Icon list with right-click context menu -->
        <DataGrid Grid.Row="1" x:Name="IconGrid" IsReadOnly="False"
                  MouseRightButtonUp="IconGrid_RightClick">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="选" Width="35"
                                        Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="进程名" Binding="{Binding ProcessName}" Width="*" MinWidth="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="提示文本" Binding="{Binding Tooltip}" Width="1.5*" MinWidth="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="区域" Binding="{Binding Area}" Width="65" IsReadOnly="True"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Rules section -->
        <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="10,8"
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock Text="隐藏规则 (每行一条，格式: 进程名|提示文本 或 仅进程名):"
                           FontWeight="SemiBold" DockPanel.Dock="Top" Margin="0,0,0,6"/>
                <TextBox x:Name="RulesBox" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" Height="70"
                         FontSize="13" Padding="4"/>
            </DockPanel>
        </Border>

        <!-- Rule controls -->
        <Border Grid.Row="3" Background="White" CornerRadius="4" Padding="10,6"
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,6,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="保存规则" Click="SaveRules_Click" Margin="0,0,6,0"/>
                    <Button Content="立即应用" Click="ApplyRules_Click" Margin="0,0,6,0"/>
                    <CheckBox x:Name="AutoApplyCheck" Content="定时隐藏" VerticalAlignment="Center"
                              Click="AutoApply_Changed" Margin="0,0,6,0"/>
                    <TextBlock Text="间隔(秒):" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="IntervalBox" Width="45" Text="10" VerticalAlignment="Center"
                             Padding="2,1" Margin="0,0,12,0"/>
                    <TextBlock x:Name="RuleStatus" VerticalAlignment="Center" Foreground="#666"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="设置" Click="Settings_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Log area -->
        <TextBox Grid.Row="4" x:Name="LogBox" IsReadOnly="True" Height="70" Margin="0,6,0,0"
                 VerticalScrollBarVisibility="Auto" FontSize="11" FontFamily="Consolas"
                 Background="#1E1E1E" Foreground="#CCCCCC" Padding="6"/>
    </Grid>
</Window>
