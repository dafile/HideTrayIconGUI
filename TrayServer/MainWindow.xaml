<Window x:Class="TrayServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayServer - 托盘图标集中管理" Width="1100" Height="750"
        MinWidth="850" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <Window.Resources>
        <!-- Client right-click menu -->
        <ContextMenu x:Key="ClientMenu" x:Shared="False">
            <MenuItem Header="查看托盘图标" Click="ViewTrayIcons_Click"/>
            <Separator/>
            <MenuItem Header="分配规则" x:Name="AssignRuleMenu"/>
            <MenuItem Header="清除规则" Click="ClearRule_Click"/>
            <Separator/>
            <MenuItem Header="重启客户端" Click="RestartClient_Click"/>
            <MenuItem Header="重启资源管理器" Click="RestartExplorer_Click"/>
            <Separator/>
            <MenuItem Header="移除客户端" Click="RemoveClient_Click"/>
        </ContextMenu>
        <!-- Tray icon right-click menu -->
        <ContextMenu x:Key="TrayIconMenu" x:Shared="False">
            <MenuItem Header="隐藏此项" Click="HideSingleIcon_Click"/>
            <Separator/>
            <MenuItem Header="添加到规则" x:Name="AddToRuleMenu"/>
            <Separator/>
            <MenuItem Header="复制进程名" Click="CopyProcessName_Click"/>
            <MenuItem Header="复制提示文本" Click="CopyTooltip_Click"/>
        </ContextMenu>
        <!-- Row style with context menu binding -->
        <Style x:Key="ClientRowStyle" TargetType="DataGridRow">
            <Setter Property="ContextMenu" Value="{StaticResource ClientMenu}"/>
            <EventSetter Event="Loaded" Handler="ClientRow_Loaded"/>
        </Style>
        <Style x:Key="TrayIconRowStyle" TargetType="DataGridRow">
            <Setter Property="ContextMenu" Value="{StaticResource TrayIconMenu}"/>
            <EventSetter Event="Loaded" Handler="TrayIconRow_Loaded"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="8,6"
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="刷新客户端" Click="RefreshClients_Click" Background="#1976D2" Foreground="White"/>
                    <Button Content="批量应用规则" Click="BatchApplyRules_Click" Background="#D32F2F" Foreground="White"/>
                    <Button Content="批量隐藏选中" Click="BatchHide_Click"/>
                    <Button Content="规则设置" Click="RulesSettings_Click" Background="#388E3C" Foreground="White"/>
                    <Button Content="过滤设置" Click="FilterSettings_Click"/>
                    <Button Content="重启资源管理器" Click="RestartExplorerSelected_Click" Background="#FF6D00" Foreground="White"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="循环间隔:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <CheckBox x:Name="CycleEnabledCheck" VerticalAlignment="Center" IsChecked="True"
                              Click="CycleEnabled_Changed"/>
                    <ComboBox x:Name="CycleIntervalCombo" Width="80" Margin="4,0,0,0"
                              SelectionChanged="CycleInterval_Changed">
                        <ComboBoxItem Content="1秒"/>
                        <ComboBoxItem Content="2秒"/>
                        <ComboBoxItem Content="3秒"/>
                        <ComboBoxItem Content="5秒"/>
                        <ComboBoxItem Content="10秒" IsSelected="True"/>
                        <ComboBoxItem Content="自定义"/>
                    </ComboBox>
                    <TextBox x:Name="CustomCycleBox" Width="50" Text="10" Padding="2,1"
                             Margin="4,0,0,0" Visibility="Collapsed"/>
                    <TextBlock Text="秒" VerticalAlignment="Center" Margin="2,0,10,0"/>
                    <TextBlock x:Name="ServerStatus" VerticalAlignment="Center" Foreground="#666"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Client list -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="已连接客户端" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DataGrid Grid.Row="1" x:Name="ClientGrid"
                      RowEditEnding="ClientGrid_RowEditEnding" IsReadOnly="False"
                      RowStyle="{StaticResource ClientRowStyle}">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="选" Width="35"
                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>
                    <DataGridTextColumn Header="主机名" Binding="{Binding HostName}" Width="90" IsReadOnly="True"/>
                    <DataGridTextColumn Header="规则" Binding="{Binding RuleName}" Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="70"/>
                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="45" IsReadOnly="True"/>
                    <DataGridTextColumn Header="连接时间" Binding="{Binding ConnectedAt, StringFormat='HH:mm:ss'}" Width="65" IsReadOnly="True"/>
                    <DataGridTextColumn Header="最后响应" Binding="{Binding LastSeen, StringFormat='HH:mm:ss'}" Width="65" IsReadOnly="True"/>
                    <DataGridTextColumn Header="图标数" Binding="{Binding IconCount}" Width="45" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Tray icons for selected client -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0">
                <TextBlock x:Name="TrayIconTitle" Text="客户端托盘图标" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <Button Content="请求刷新" Click="RequestTrayIcons_Click" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
            <DataGrid Grid.Row="1" x:Name="TrayIconGrid" IsReadOnly="True"
                      RowStyle="{StaticResource TrayIconRowStyle}">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="选" Width="35"
                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>
                    <DataGridTextColumn Header="进程名" Binding="{Binding ProcessName}" Width="*" MinWidth="100"/>
                    <DataGridTextColumn Header="提示文本" Binding="{Binding Tooltip}" Width="2*" MinWidth="120"/>
                    <DataGridTextColumn Header="区域" Binding="{Binding Area}" Width="65"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Log area -->
        <TextBox Grid.Row="3" x:Name="LogBox" IsReadOnly="True" Height="80" Margin="0,8,0,0"
                 VerticalScrollBarVisibility="Auto" FontSize="11" FontFamily="Consolas"
                 Background="#1E1E1E" Foreground="#CCCCCC" Padding="6"/>
    </Grid>
</Window>
