<Window x:Class="TrayServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayServer - 托盘图标集中管理" Width="1100" Height="750"
        MinWidth="850" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="8,6"
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="刷新客户端" Click="RefreshClients_Click" Background="#1976D2" Foreground="White"/>
                    <Button Content="批量应用规则" Click="BatchApplyRules_Click" Background="#D32F2F" Foreground="White"/>
                    <Button Content="批量隐藏选中" Click="BatchHide_Click"/>
                    <Button Content="规则设置" Click="RulesSettings_Click" Background="#388E3C" Foreground="White"/>
                    <Button Content="过滤设置" Click="FilterSettings_Click"/>
                    <Button Content="重启资源管理器" Click="RestartExplorerSelected_Click" Background="#FF6D00" Foreground="White"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="循环间隔:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <CheckBox x:Name="CycleEnabledCheck" VerticalAlignment="Center" IsChecked="True"
                              Click="CycleEnabled_Changed"/>
                    <ComboBox x:Name="CycleIntervalCombo" Width="80" Margin="4,0,0,0"
                              SelectionChanged="CycleInterval_Changed">
                        <ComboBoxItem Content="1秒"/>
                        <ComboBoxItem Content="2秒"/>
                        <ComboBoxItem Content="3秒"/>
                        <ComboBoxItem Content="5秒"/>
                        <ComboBoxItem Content="10秒" IsSelected="True"/>
                        <ComboBoxItem Content="自定义"/>
                    </ComboBox>
                    <TextBox x:Name="CustomCycleBox" Width="50" Text="10" Padding="2,1"
                             Margin="4,0,0,0" Visibility="Collapsed"/>
                    <TextBlock Text="秒" VerticalAlignment="Center" Margin="2,0,10,0"/>
                    <TextBlock x:Name="ServerStatus" VerticalAlignment="Center" Foreground="#666"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Client list -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="已连接客户端" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ListView Grid.Row="1" x:Name="ClientList" SelectionMode="Single"
                      MouseDoubleClick="ClientList_DoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="35">
                            <GridViewColumn.Header>
                                <TextBlock Text="选"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="主机名" Width="90" DisplayMemberBinding="{Binding HostName}"/>
                        <GridViewColumn Header="规则" Width="70" DisplayMemberBinding="{Binding RuleName}"/>
                        <GridViewColumn Header="备注" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             BorderThickness="0" Padding="2,1"
                                             LostFocus="Remark_LostFocus"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="IP" Width="110" DisplayMemberBinding="{Binding IpAddress}"/>
                        <GridViewColumn Header="状态" Width="45" DisplayMemberBinding="{Binding Status}"/>
                        <GridViewColumn Header="连接时间" Width="70" DisplayMemberBinding="{Binding ConnectedAt, StringFormat=HH:mm:ss}"/>
                        <GridViewColumn Header="最后响应" Width="70" DisplayMemberBinding="{Binding LastSeen, StringFormat=HH:mm:ss}"/>
                        <GridViewColumn Header="图标数" Width="50" DisplayMemberBinding="{Binding IconCount}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- Tray icons -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0">
                <TextBlock x:Name="TrayIconTitle" Text="客户端托盘图标" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <Button Content="请求刷新" Click="RequestTrayIcons_Click" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
            <ListView Grid.Row="1" x:Name="TrayIconList" SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="35">
                            <GridViewColumn.Header>
                                <TextBlock Text="选"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="进程名" Width="150" DisplayMemberBinding="{Binding ProcessName}"/>
                        <GridViewColumn Header="提示文本" Width="300" DisplayMemberBinding="{Binding Tooltip}"/>
                        <GridViewColumn Header="区域" Width="65" DisplayMemberBinding="{Binding Area}"/>
                        <GridViewColumn Header="状态" Width="60" DisplayMemberBinding="{Binding Status}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- Log -->
        <TextBox Grid.Row="3" x:Name="LogBox" IsReadOnly="True" Height="80" Margin="0,8,0,0"
                 VerticalScrollBarVisibility="Auto" FontSize="11" FontFamily="Consolas"
                 Background="#1E1E1E" Foreground="#CCCCCC" Padding="6"/>
    </Grid>
</Window>
