<Window x:Class="TrayServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayServer - 托盘图标集中管理" Width="1050" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <Window.Resources>
        <ContextMenu x:Key="ClientMenu">
            <MenuItem Header="查看托盘图标" Click="ViewTrayIcons_Click"/>
            <MenuItem Header="隐藏选中项" Click="HideSelected_Click"/>
            <MenuItem Header="重启客户端" Click="RestartClient_Click"/>
            <MenuItem Header="重启资源管理器" Click="RestartExplorer_Click"/>
            <Separator/>
            <MenuItem Header="移除客户端" Click="RemoveClient_Click"/>
        </ContextMenu>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="8,6"
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="刷新客户端" Click="RefreshClients_Click" Background="#1976D2" Foreground="White"/>
                    <Button Content="全部应用规则" Click="ApplyAllRules_Click" Background="#D32F2F" Foreground="White"/>
                    <Button Content="批量隐藏选中" Click="BatchHide_Click"/>
                    <Button Content="规则设置" Click="RulesSettings_Click" Background="#388E3C" Foreground="White"/>
                    <Button Content="过滤设置" Click="FilterSettings_Click"/>
                </StackPanel>
                <TextBlock x:Name="ServerStatus" DockPanel.Dock="Right" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Foreground="#666"/>
            </DockPanel>
        </Border>

        <!-- Client list -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="已连接客户端" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DataGrid Grid.Row="1" x:Name="ClientGrid" MouseRightButtonUp="ClientGrid_RightClick">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="选" Width="35"
                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>
                    <DataGridTextColumn Header="主机名" Binding="{Binding HostName}" Width="*" MinWidth="100"/>
                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60"/>
                    <DataGridTextColumn Header="连接时间" Binding="{Binding ConnectedAt, StringFormat='HH:mm:ss'}" Width="80"/>
                    <DataGridTextColumn Header="最后响应" Binding="{Binding LastSeen, StringFormat='HH:mm:ss'}" Width="80"/>
                    <DataGridTextColumn Header="图标数" Binding="{Binding IconCount}" Width="55"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Tray icons for selected client -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0">
                <TextBlock Text="客户端托盘图标" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <Button Content="请求刷新" Click="RequestTrayIcons_Click" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
            <DataGrid Grid.Row="1" x:Name="TrayIconGrid">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="选" Width="35"
                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>
                    <DataGridTextColumn Header="进程名" Binding="{Binding ProcessName}" Width="*" MinWidth="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="提示文本" Binding="{Binding Tooltip}" Width="1.5*" MinWidth="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="区域" Binding="{Binding Area}" Width="65" IsReadOnly="True"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Log area -->
        <TextBox Grid.Row="4" x:Name="LogBox" IsReadOnly="True" Height="90" Margin="0,8,0,0"
                 VerticalScrollBarVisibility="Auto" FontSize="11" FontFamily="Consolas"
                 Background="#1E1E1E" Foreground="#CCCCCC" Padding="6"/>
    </Grid>
</Window>
