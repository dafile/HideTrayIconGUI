<Window x:Class="TrayServer.RuleSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择规则" Width="300" Height="250"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="选择要应用的规则:" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <ListBox Grid.Row="1" x:Name="RuleListBox"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Click="OK_Click" Width="70" Margin="0,0,8,0"
                    Background="#1976D2" Foreground="White"/>
            <Button Content="取消" Click="Cancel_Click" Width="70"/>
        </StackPanel>
    </Grid>
</Window>
