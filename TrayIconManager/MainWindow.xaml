<Window x:Class="TrayIconManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TrayIconManager.Converters"
        Title="TrayIconManager - 系统托盘图标管理"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Closing="Window_Closing"
        Loaded="Window_Loaded">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:MatchTypeConverter x:Key="MatchTypeConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:IconToImageSourceConverter x:Key="IconToImage"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,14">
            <DockPanel>
                <TextBlock Text="TrayIconManager" Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="系统托盘图标管理工具" Foreground="#B3FFFFFF" FontSize="13"
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="12,8" Background="Transparent"
                    BorderThickness="0" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="border" Background="Transparent"
                                        BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="content" ContentSource="Header"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush"
                                                Value="{StaticResource PrimaryBrush}"/>
                                        <Setter TargetName="content" Property="TextElement.Foreground"
                                                Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="content" Property="TextElement.Foreground"
                                                Value="{StaticResource TextSecondaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: Tray Icons -->
            <TabItem Header="当前托盘图标">
                <Grid Margin="0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="12,8"
                            BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" Margin="0,0,0,8">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <Button Content="全部刷新" Style="{StaticResource ModernButton}"
                                        Click="Refresh_Click" Margin="0,0,8,0"/>
                                <Button Content="隐藏选中" Style="{StaticResource DangerButton}"
                                        Click="HideSelected_Click" Margin="0,0,8,0"/>
                                <Button Content="显示选中" Style="{StaticResource OutlineButton}"
                                        Click="ShowSelected_Click" Margin="0,0,8,0"/>
                                <Button Content="查看日志" Style="{StaticResource OutlineButton}"
                                        Click="ViewLog_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                        HorizontalAlignment="Right">
                                <CheckBox Content="全选" x:Name="SelectAllCheckBox"
                                          VerticalAlignment="Center" Margin="0,0,12,0"
                                          Click="SelectAll_Click"/>
                                <TextBlock Text="{Binding IconCount, StringFormat='共 {0} 个图标'}"
                                           VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Tray Icons DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="TrayIconGrid"
                              ItemsSource="{Binding TrayIcons}"
                              LoadingRow="TrayIconGrid_LoadingRow"
                              MouseDoubleClick="TrayIconGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay}"
                                                    Width="40" Header="选择">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                            <DataGridTemplateColumn Header="图标" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding Icon, Converter={StaticResource IconToImage}}"
                                               Width="20" Height="20" Margin="8,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="进程名" Binding="{Binding ProcessName}" Width="*"
                                                MinWidth="100"/>
                            <DataGridTextColumn Header="提示文本" Binding="{Binding TooltipText}" Width="1.5*"
                                                MinWidth="120"/>
                            <DataGridTextColumn Header="区域" Binding="{Binding Area}" Width="70"/>
                            <DataGridTemplateColumn Header="状态" Width="65">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="6,2"
                                                HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Status}" Foreground="White"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Quick rule add -->
                    <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="12,8"
                            BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" Margin="0,8,0,0">
                        <DockPanel>
                            <TextBlock Text="快速添加规则:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontWeight="SemiBold"/>
                            <TextBox x:Name="QuickRuleText" Width="200" Margin="0,0,8,0" Padding="4,3"/>
                            <ComboBox x:Name="QuickRuleType" Width="90" Margin="0,0,8,0" Padding="4,2">
                                <ComboBoxItem Content="进程名" IsSelected="True"/>
                                <ComboBoxItem Content="提示文本"/>
                                <ComboBoxItem Content="两者皆可"/>
                            </ComboBox>
                            <Button Content="添加隐藏规则" Style="{StaticResource ModernButton}"
                                    Click="AddQuickRule_Click"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Rules -->
            <TabItem Header="隐藏规则管理">
                <Grid Margin="0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Rules toolbar -->
                    <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="12,8"
                            BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" Margin="0,0,0,8">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <Button Content="添加规则" Style="{StaticResource ModernButton}"
                                        Click="AddRule_Click" Margin="0,0,8,0"/>
                                <Button Content="删除选中" Style="{StaticResource DangerButton}"
                                        Click="DeleteRule_Click" Margin="0,0,8,0"/>
                                <Button Content="立即应用" Style="{StaticResource OutlineButton}"
                                        Click="ApplyRules_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                        HorizontalAlignment="Right">
                                <TextBlock x:Name="PollingStatus" VerticalAlignment="Center"
                                           Margin="0,0,12,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Button x:Name="TogglePollingButton" Content="启动轮询"
                                        Style="{StaticResource OutlineButton}"
                                        Click="TogglePolling_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Rules DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="RulesGrid"
                              ItemsSource="{Binding Rules}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsEnabled, Mode=TwoWay}"
                                                    Header="启用" Width="50">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"
                                                MinWidth="100"/>
                            <DataGridTextColumn Header="匹配文本" Binding="{Binding MatchText}" Width="*"
                                                MinWidth="120"/>
                            <DataGridTemplateColumn Header="匹配类型" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MatchType, Converter={StaticResource MatchTypeConverter}}"
                                                   HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                                Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Rule editor -->
                    <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="12,10"
                            BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1" x:Name="RuleNameBox" Margin="0,0,12,0" Padding="4,3"/>
                            <TextBlock Grid.Column="2" Text="匹配文本:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="3" x:Name="RuleMatchBox" Margin="0,0,12,0" Padding="4,3"/>
                            <ComboBox Grid.Column="4" x:Name="RuleTypeBox" Width="90" Margin="0,0,12,0" Padding="4,2">
                                <ComboBoxItem Content="进程名" IsSelected="True"/>
                                <ComboBoxItem Content="提示文本"/>
                                <ComboBoxItem Content="两者皆可"/>
                            </ComboBox>
                            <Button Grid.Column="5" Content="保存规则" Style="{StaticResource ModernButton}"
                                    Click="SaveRule_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: Settings -->
            <TabItem Header="设置">
                <Border Background="White" CornerRadius="4" Padding="20,16"
                        BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" Margin="0,8">
                    <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                        <TextBlock Text="程序行为" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <CheckBox x:Name="MinimizeToTrayCheck" Content="关闭窗口时最小化到托盘（而非退出程序）"
                                  IsChecked="{Binding Settings.MinimizeToTrayOnClose}"
                                  Margin="0,0,0,12" FontSize="14"/>

                        <CheckBox x:Name="AutoStartPollingCheck" Content="启动时自动开始轮询隐藏规则"
                                  IsChecked="{Binding Settings.AutoStartPolling}"
                                  Margin="0,0,0,12" FontSize="14"/>

                        <CheckBox x:Name="StartMinimizedCheck" Content="启动时最小化到托盘"
                                  IsChecked="{Binding Settings.StartMinimized}"
                                  Margin="0,0,0,20" FontSize="14"/>

                        <Separator Margin="0,0,0,16"/>

                        <TextBlock Text="轮询设置" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="轮询间隔（秒）:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="PollingIntervalBox" Width="80" Padding="4,3"
                                     Text="{Binding Settings.PollingIntervalSeconds}"/>
                        </StackPanel>

                        <Button Content="保存设置" Style="{StaticResource ModernButton}"
                                Click="SaveSettings_Click" HorizontalAlignment="Left"/>

                        <Separator Margin="0,20,0,16"/>

                        <TextBlock Text="关于" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="TrayIconManager v1.0" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="基于 hideTrayIcon.exe 命令行工具的图形化管理界面"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="规则文件保存在程序所在目录的 hide_rules.json 中"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel>
                <TextBlock x:Name="StatusText" Text="就绪" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="LogText" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
